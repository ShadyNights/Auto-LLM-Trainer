# .env.example
# ==========================================
# Provider Keys (Secrets)
# ==========================================
GEMINI_API_KEY=your_api_key_here

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# Note: You can either use a full connection string (DATABASE_URL) 
# OR individual connection parameters (PGHOST, etc).

DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# Or use individual connection parameters:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=traveler_db
# PGUSER=traveler_app_user
# PGPASSWORD=your_secure_password_here

# ==========================================
# Auto-Training & Pipeline Settings
# ==========================================
AUTO_TRAINING_ENABLED=true
AUTO_TRAINING_THRESHOLD=3
AUTO_TRAINING_INTERVAL=300

# ==========================================
# Application Settings
# ==========================================
DEBUG=false
LOG_LEVEL=INFO
